<Window x:Class="ElKharis.Views.UtilisateursWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="El-Kharis - Utilisateurs:ElKharis.Views"
        mc:Ignorable="d"
        Title="El-Kharis - Clients" Height="700" Width="1100">

    <Grid Margin="0,0,0,-6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1A365D" BorderThickness="0,0,1,0" BorderBrush="#E2E8F0" Margin="0,0,34,0">
            <Grid Margin="10,20,10,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="1" Margin="0,0,10,0">
                    <Image Source="/Resources/logo.jpeg" Height="80" Width="130" HorizontalAlignment="Center" Margin="0,0,0,-5" Stretch="Uniform"/>
                    <TextBlock Text="EL-KHARIS" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,0"/>
                    <TextBlock Text="L'excellence au service de votre éclat" Foreground="#CBD5E0" FontSize="10" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,0,0,0" TextWrapping="Wrap" TextAlignment="Center"/>

                    <Border Background="#2B6CB0" CornerRadius="8" Padding="1" Margin="0,5,0,10">
                        <StackPanel HorizontalAlignment="Center" Margin="5">
                            <TextBlock x:Name="TxtUserNom" Text="Nom de l'utilisateur" Foreground="White" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                            <TextBlock x:Name="TxtUserRole" Text="Rôle" Foreground="#CBD5E0" FontSize="10" FontWeight="Medium" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Button Content="📊  Tableau de bord" Background="Transparent" Foreground="#E2E8F0" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Cursor="Hand" Click="BtnDashboard_Click"/>
                    <Button Content="🧺  Commandes" Background="Transparent" Foreground="White" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Click="BtnCommandes_Click"/>

                    <Button Content="👥 Clients" Background="Transparent" Foreground="White" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Click="BtnClients_Click"/>

                    <Button Content="💳 Factures &amp; Reçus" Background="Transparent" Foreground="White" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Click="BtnFactures_Click"/>
                    <Button x:Name="BtnArticles" Content="👕 Articles" Background="Transparent" Foreground="#E2E8F0" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Cursor="Hand" Margin="0,5,0,0" Click="BtnArticles_Click"/>
                    <Button x:Name="BtnServices" Content="🕒 Services" Background="Transparent" Foreground="#E2E8F0" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Cursor="Hand" Margin="0,5,0,0" Click="BtnServices_Click"/>

                    <Border Background="#2B6CB0" CornerRadius="8" Margin="0,5,0,0">
                        <Button x:Name="BtnUtilisateurs" Content="👥 Utilisateurs" Background="Transparent" Foreground="White" FontWeight="Bold" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Cursor="Hand"/>
                    </Border>
                </StackPanel>

                <Button Grid.Row="2" Content="Déconnexion" Background="#E53E3E" Foreground="White" FontWeight="Bold" FontSize="14" Height="40" Margin="15,0,15,0" Cursor="Hand" BorderThickness="0" Click="BtnLogout_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,10,0,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Utilisateurs" FontSize="26" FontWeight="Bold" Foreground="#0A2540" Height="28" Width="10019"/>
                    <TextBlock Text="Consultez, recherchez ou gérez les accès des employés de votre pressing" FontSize="14" Foreground="#639FAB" Height="29" Width="1006"/>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Foreground="#A0AEC0" FontWeight="Bold" FontSize="18" Cursor="Hand" Click="BtnQuitter_Click"/>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,25">
                    <Button Content="🔍" FontSize="14" Background="#2B6CB0" Foreground="White" Width="36" Height="36" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Border BorderThickness="1.5" BorderBrush="#CBD5E0" CornerRadius="8" Background="White" Padding="12.5" Width="450" Height="36" RenderTransformOrigin="0.482,1.543">
                        <Grid>
                            <TextBox x:Name="TxtRecherche" BorderThickness="0" Background="Transparent" FontSize="12" Foreground="#2D3748" VerticalContentAlignment="Center" TextChanged="TxtRecherche_TextChanged"/>
                            <TextBlock Text="Rechercher par ID, nom d'utilisateur, email..." Foreground="#A0AEC0" IsHitTestVisible="False" VerticalAlignment="Center" Margin="5,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=TxtRecherche}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnModifier" Content="✏️ Modifier le rôle" Margin="0,0,10,0"
                            Width="140" Height="35" Background="#F39C12" Foreground="White" 
                            FontWeight="Bold" BorderThickness="0" Click="BtnModifier_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button x:Name="BtnAjouter" Content="➕ Nouvel Utilisateur" 
                            Width="155" Height="35" Background="#00A8CC" Foreground="White" 
                            FontWeight="Bold" BorderThickness="0" Click="BtnAjouter_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="10" Margin="-15,51,0,0" Grid.RowSpan="2">
                <DataGrid x:Name="DgUtilisateurs" AutoGenerateColumns="False" IsReadOnly="True" 
                          SelectionMode="Single" Background="White" RowHeight="35"
                          BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E0E0E0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding id}" Width="50"/>
                        <DataGridTextColumn Header="Nom d'utilisateur" Binding="{Binding nom_utilisateur}" Width="2*"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding email}" Width="2*"/>

                        <DataGridTextColumn Header="Rôle" Binding="{Binding role}" Width="1.5*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="Administrateur">
                                            <Setter Property="Foreground" Value="#28A745"/>
                                        </Trigger>
                                        <Trigger Property="Text" Value="Réceptionniste">
                                            <Setter Property="Foreground" Value="#1A365D"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Width="*" Header="Action">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="🗑️" Background="Transparent" BorderThickness="0" 
                                            Foreground="Red" FontSize="14" Cursor="Hand" HorizontalAlignment="Center"
                                            Click="BtnSupprimer_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>
