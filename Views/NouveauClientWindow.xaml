<Window x:Class="ElKharis.Views.NouveauClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ElKharis.Views"
        mc:Ignorable="d"
        Title="El-Kharis - Fiche Client" Height="580" Width="480"
        WindowStartupLocation="CenterOwner" 
        WindowStyle="None" 
        ResizeMode="NoResize"
        Background="#F4F6FA">

    <Border CornerRadius="15" Background="White" Margin="15">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Fiche Client" FontSize="22" FontWeight="Bold" Foreground="#1A365D"/>
                    <TextBlock Text="Saisissez les informations du client pour continuer" FontSize="12" Foreground="#718096" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Foreground="#A0AEC0" FontWeight="Bold" FontSize="16" Cursor="Hand" Click="BtnFermer_Click"/>
            </Grid>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Focusable="False" Margin="0,62,0,28" Grid.RowSpan="3">
                <StackPanel Margin="0,5,5,5">
                    <TextBox x:Name="TxtIdClient" Visibility="Collapsed"/>

                    <TextBlock Text="Nom " FontSize="12" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,5,0,4"/>
                    <Border BorderThickness="1" BorderBrush="#CBD5E0" CornerRadius="6" Background="#F7FAFC" Padding="5" Margin="0,0,0,10">
                        <TextBox x:Name="TxtNom" BorderThickness="0" Background="Transparent" FontSize="14" Foreground="#2D3748" VerticalContentAlignment="Center" Height="25"/>
                    </Border>

                    <TextBlock Text="Prénom" FontSize="12" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,5,0,4"/>
                    <Border BorderThickness="1" BorderBrush="#CBD5E0" CornerRadius="6" Background="#F7FAFC" Padding="5" Margin="0,0,0,10">
                        <TextBox x:Name="TxtPrenom" BorderThickness="0" Background="Transparent" FontSize="14" Foreground="#2D3748" VerticalContentAlignment="Center" Height="25"/>
                    </Border>

                    <Grid Margin="0,5,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Sexe " FontSize="12" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,4"/>
                            <Border BorderThickness="1" BorderBrush="#CBD5E0" CornerRadius="6" Background="#F7FAFC" Padding="3">
                                <ComboBox x:Name="CboSexe" BorderThickness="0" Background="Transparent" FontSize="14" Foreground="#2D3748" VerticalContentAlignment="Center" Height="25" SelectedIndex="0">
                                    <ComboBoxItem Content="M"/>
                                    <ComboBoxItem Content="F"/>
                                </ComboBox>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Téléphone " FontSize="12" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,4"/>
                            <Border BorderThickness="1" BorderBrush="#CBD5E0" CornerRadius="6" Background="#F7FAFC" Padding="5">
                                <TextBox x:Name="TxtTelephone" BorderThickness="0" Background="Transparent" FontSize="14" Foreground="#2D3748" VerticalContentAlignment="Center" Height="25"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Email" FontSize="12" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,5,0,4"/>
                    <Border BorderThickness="1" BorderBrush="#CBD5E0" CornerRadius="6" Background="#F7FAFC" Padding="5" Margin="0,0,0,10">
                        <TextBox x:Name="TxtEmail" BorderThickness="0" Background="Transparent" FontSize="14" Foreground="#2D3748" VerticalContentAlignment="Center" Height="25"/>
                    </Border>

                    <Grid Margin="0,5,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="Ville" FontSize="12" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,4"/>
                            <Border BorderThickness="1" BorderBrush="#CBD5E0" CornerRadius="6" Background="#F7FAFC" Padding="5">
                                <TextBox x:Name="TxtVille" BorderThickness="0" Background="Transparent" FontSize="14" Foreground="#2D3748" VerticalContentAlignment="Center" Height="25"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <TextBlock Text="Quartier" FontSize="12" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,4"/>
                            <Border BorderThickness="1" BorderBrush="#CBD5E0" CornerRadius="6" Background="#F7FAFC" Padding="5">
                                <TextBox x:Name="TxtQuartier" BorderThickness="0" Background="Transparent" FontSize="14" Foreground="#2D3748" VerticalContentAlignment="Center" Height="25"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Border BorderThickness="1" BorderBrush="#BEE3F8" Background="#EBF8FF" CornerRadius="6" Padding="10" Margin="0,5,0,5">
                        <CheckBox x:Name="ChkOuvrirCommande" Content="Prendre immédiatement une commande pour ce client" FontSize="12" FontWeight="SemiBold" Foreground="#2B6CB0" VerticalContentAlignment="Center" Cursor="Hand"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <UniformGrid Grid.Row="1" Columns="2" Rows="1" Margin="0,425,0,-16" Grid.RowSpan="2">
                <Button x:Name="BtnAnnuler" Content="Annuler" Background="#E2E8F0" Foreground="#4A5568" FontSize="13" FontWeight="SemiBold" Margin="0,0,5,0"  BorderThickness="0" Cursor="Hand" Click="BtnAnnuler_Click"/>
                <Button x:Name="BtnEnregistrer" Content="Enregistrer" Background="#2B6CB0" Foreground="White" FontSize="13" FontWeight="Bold" Margin="5,0,0,0"  BorderThickness="0" Cursor="Hand" Click="BtnEnregistrer_Click"/>
            </UniformGrid>
        </Grid>
    </Border>
</Window>