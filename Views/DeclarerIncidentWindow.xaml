<Window x:Class="ElKharis.Views.DeclarerIncidentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Déclarer un incident" Height="400" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F7FAFC">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="⚠️ Déclarer un incident" FontSize="20" FontWeight="Bold" Foreground="#1A365D"/>
            <TextBlock Text="Renseignez les détails de l'anomalie sur cet article" FontSize="12" Foreground="#718096" Margin="0,2,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Type d'incident" FontWeight="SemiBold" Foreground="#2D3748" Margin="0,0,0,5"/>
            <ComboBox x:Name="CboTypeIncident" Height="35" VerticalContentAlignment="Center" Padding="5,0">
                <ComboBoxItem Content="Défaut constaté au dépôt"/>
                <ComboBoxItem Content="Article abîmé au lavage/repassage"/>
                <ComboBoxItem Content="Article égaré / perdu"/>
                <ComboBoxItem Content="Autre anomalie"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Responsabilité" FontWeight="SemiBold" Foreground="#2D3748" Margin="0,0,0,5"/>
            <ComboBox x:Name="CboResponsabilite" Height="35" VerticalContentAlignment="Center" Padding="5,0">
                <ComboBoxItem Content="Client (Défaut d'origine)"/>
                <ComboBoxItem Content="Pressing (Erreur interne)"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,15">
            <TextBlock Text="Description précise du problème" FontWeight="SemiBold" Foreground="#2D3748" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtDescription" Height="100" TextWrapping="Wrap" AcceptsReturn="True" 
                     Padding="8" VerticalScrollBarVisibility="Auto" BorderBrush="#CBD5E0"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Annuler" Width="100" Height="35" Background="#E2E8F0" Foreground="#4A5568" 
                    FontWeight="Bold" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand" Click="BtnAnnuler_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="Enregistrer" Width="120" Height="35" Background="#00A8CC" Foreground="White" 
                    FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnEnregistrer_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>