<Window x:Class="ElKharis.Views.ClientsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="El-Kharis - Clients" Height="720" Width="1200"
        WindowStartupLocation="CenterScreen" WindowStyle="None" ResizeMode="NoResize"
        Background="#F4F6FA">

    <Grid Margin="0,0,0,-6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#1A365D" BorderThickness="0,0,1,0" BorderBrush="#E2E8F0" Margin="0,0,34,0">
            <Grid Margin="10,20,10,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="1" Margin="0,0,10,0">
                    <Image Source="/Resources/logo.png" Height="80" Width="80" HorizontalAlignment="Center" Margin="0,0,0,-5" Stretch="Uniform"/>
                    <TextBlock Text="EL-KHARIS" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>

                    <Border Background="#2B6CB0" CornerRadius="8" Padding="1" Margin="0,5,0,10">
                        <StackPanel HorizontalAlignment="Center" Margin="5">
                            <TextBlock x:Name="TxtUserNom" Text="Nom de l'utilisateur" Foreground="White" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                            <TextBlock x:Name="TxtUserRole" Text="Rôle" Foreground="#CBD5E0" FontSize="10" FontWeight="Medium" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Button Content="📊  Tableau de bord" Background="Transparent" Foreground="#E2E8F0" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Cursor="Hand" Click="BtnRetourDashboard_Click"/>
                    <Button Content="🧺  Commandes" Background="Transparent" Foreground="White" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Click="BtnCommandes_Click"/>
                    <Border Background="#2B6CB0" CornerRadius="8" Margin="0,5,0,0">
                        <Button Content="👥 Clients" Background="Transparent" Foreground="White" FontWeight="Bold" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0"/>
                    </Border>
                    <Button Content="👕 Articles" Background="Transparent" Foreground="#E2E8F0" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Cursor="Hand" Margin="0,5,0,0" Click="BtnArticles_Click"/>
                    <Button Content="🕒 Services" Background="Transparent" Foreground="#E2E8F0" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Cursor="Hand" Margin="0,5,0,0" Click="BtnServices_Click"/>
                </StackPanel>

                <Button Grid.Row="2" Content="Déconnexion" Background="#E53E3E" Foreground="White" FontWeight="Bold" FontSize="14" Height="40" Margin="15,0,15,0" Cursor="Hand" BorderThickness="0" Click="BtnLogout_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,25">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Clients" FontSize="26" FontWeight="Bold" Foreground="#0A2540" Height="28" Width="1019"/>
                    <TextBlock Text="Consultez, recherchez ou gérez les fiches clients de votre pressing" FontSize="14" Foreground="#639FAB" Height="26" Width="1013"/>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Foreground="#A0AEC0" FontWeight="Bold" FontSize="18" Cursor="Hand" Click="BtnQuitter_Click"/>
            </Grid>


            <Grid Grid.Row="1" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="🔍" VerticalAlignment="Center" FontSize="16" Margin="0,0,10,0"/>
                    <TextBox x:Name="TxtRecherche" Width="350" Height="27" 
                             VerticalContentAlignment="Center" Padding="10,0"
                             TextChanged="TxtRecherche_TextChanged" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnModifierClient" Content="✏️ Modifier" Margin="0,0,10,0"
                            Width="120" Height="35" Background="#F39C12" Foreground="White" 
                            FontWeight="Bold" BorderThickness="0" Click="BtnModifierClient_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button x:Name="BtnNouveauClient" Content="➕ Nouveau Client" 
                            Width="160" Height="35" Background="#00A8CC" Foreground="White" 
                            FontWeight="Bold" BorderThickness="0" Click="BtnNouveauClient_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="10" Margin="-37,50,0,0" Grid.RowSpan="2">
                <DataGrid x:Name="DgClients" AutoGenerateColumns="False" IsReadOnly="True" 
                          SelectionMode="Single" Background="White" RowHeight="35"
                          BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E0E0E0"
                          MouseDoubleClick="DgClients_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding id_client}" Width="50"/>
                        <DataGridTextColumn Header="Nom" Binding="{Binding nom}" Width="130"/>
                        <DataGridTextColumn Header="Prénom" Binding="{Binding prenom}" Width="130"/>
                        <DataGridTextColumn Header="Sexe" Binding="{Binding sexe}" Width="50"/>
                        <DataGridTextColumn Header="Téléphone" Binding="{Binding telephone}" Width="110"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding email}" Width="140"/>
                        <DataGridTextColumn Header="Ville" Binding="{Binding ville}" Width="90"/>
                        <DataGridTextColumn Header="Quartier" Binding="{Binding quartier}" Width="100"/>
                        <DataGridTextColumn Header="Fidélité" Binding="{Binding fidelite}" Width="70"/>

                        <DataGridTemplateColumn Width="*" Header="Action">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="🗑️" Background="Transparent" BorderThickness="0" 
                                            Foreground="Red" FontSize="14" Cursor="Hand" HorizontalAlignment="Center"
                                            Click="BtnSupprimerClient_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>
