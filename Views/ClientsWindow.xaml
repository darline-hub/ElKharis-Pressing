<Window x:Class="ElKharis.Views.ClientsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ElKharis.Views"
        mc:Ignorable="d"
        Title="El-Kharis - Clients" Height="700" Width="1100">

    <Grid Margin="0,0,0,-6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>

        <Border Grid.Column="0" Background="#1A365D" BorderThickness="0,0,1,0" BorderBrush="#E2E8F0" Margin="0,0,34,0">
            <Grid Margin="10,20,10,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="1" Margin="0,0,10,0">
                    <Image Source="/Resources/logo.jpeg" Height="80" Width="130" HorizontalAlignment="Center" Margin="0,0,0,-5" Stretch="Uniform"/>
                    <TextBlock Text="EL-KHARIS" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,0"/>
                    <TextBlock Text="L'excellence au service de votre éclat" Foreground="#CBD5E0" FontSize="10" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,0,0,0" TextWrapping="Wrap" TextAlignment="Center"/>

                    <Border Background="#2B6CB0" CornerRadius="8" Padding="1" Margin="0,5,0,10">
                        <StackPanel HorizontalAlignment="Center" Margin="5">
                            <TextBlock x:Name="TxtUserNom" Text="Nom de l'utilisateur" Foreground="White" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                            <TextBlock x:Name="TxtUserRole" Text="Rôle" Foreground="#CBD5E0" FontSize="10" FontWeight="Medium" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Button Content="📊  Tableau de bord" Background="Transparent" Foreground="#E2E8F0" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Cursor="Hand" Click="BtnDashboard_Click"/>
                    <Button Content="🧺  Commandes" Background="Transparent" Foreground="White" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Click="BtnCommandes_Click"/>
                    <Border Background="#2B6CB0" CornerRadius="8" Margin="0,5,0,0">
                        <Button Content="👥 Clients" Background="Transparent" Foreground="White" FontWeight="Bold" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0"/>
                    </Border>
                    <Button Content="💳 Factures &amp; Reçus" Background="Transparent" Foreground="White" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Click="BtnFactures_Click"/>
                    <Button x:Name="BtnArticles" Content="👕 Articles" Background="Transparent" Foreground="#E2E8F0" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Cursor="Hand" Margin="0,5,0,0" Click="BtnArticles_Click"/>
                    <Button x:Name="BtnServices" Content="🕒 Services" Background="Transparent" Foreground="#E2E8F0" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Cursor="Hand" Margin="0,5,0,0" Click="BtnServices_Click"/>
                </StackPanel>

                <Button Grid.Row="2" Content="Déconnexion" Background="#E53E3E" Foreground="White" FontWeight="Bold" FontSize="14" Height="40" Margin="15,0,15,0" Cursor="Hand" BorderThickness="0" Click="BtnLogout_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,10,0,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Clients" FontSize="26" FontWeight="Bold" Foreground="#0A2540" Height="28" Width="10019"/>
                    <TextBlock Text="Consultez, recherchez ou gérez les fiches clients de votre pressing" FontSize="14" Foreground="#639FAB" Height="29" Width="1006"/>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Foreground="#A0AEC0" FontWeight="Bold" FontSize="18" Cursor="Hand" Click="BtnQuitter_Click"/>
            </Grid>


            <Grid Grid.Row="1" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

               
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,25">
                    <Button Content="🔍" FontSize="14" Background="#2B6CB0" Foreground="White" Width="36" Height="36" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Border BorderThickness="1.5" BorderBrush="#CBD5E0" CornerRadius="8" Background="White" Padding="12,5" Width="450" Height="36">
                        <Grid>
                            <TextBox x:Name="TxtRecherche" BorderThickness="0" Background="Transparent" FontSize="14" Foreground="#2D3748" VerticalContentAlignment="Center" TextChanged="TxtRecherche_TextChanged"/>
                            <TextBlock Text="Rechercher par ID, nom de client..." Foreground="#A0AEC0" IsHitTestVisible="False" VerticalAlignment="Center" Margin="5,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=TxtRecherche}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </StackPanel>




                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnModifierClient" Content="✏️ Modifier" Margin="0,0,10,0"
                            Width="120" Height="35" Background="#F39C12" Foreground="White" 
                            FontWeight="Bold" BorderThickness="0" Click="BtnModifierClient_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button x:Name="BtnNouveauClient" Content="➕ Nouveau Client" 
                            Width="160" Height="35" Background="#00A8CC" Foreground="White" 
                            FontWeight="Bold" BorderThickness="0" Click="BtnNouveauClient_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="10" Margin="-37,50,0,0" Grid.RowSpan="2">
                <DataGrid x:Name="DgClients" AutoGenerateColumns="False" IsReadOnly="True" 
                          SelectionMode="Single" Background="White" RowHeight="35"
                          BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E0E0E0"
                          MouseDoubleClick="DgClients_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding id_client}" Width="30"/>
                        <DataGridTextColumn Header="Nom" Binding="{Binding nom}" Width="100"/>
                        <DataGridTextColumn Header="Prénom" Binding="{Binding prenom}" Width="100"/>
                        <DataGridTextColumn Header="Sexe" Binding="{Binding sexe}" Width="40"/>
                        <DataGridTextColumn Header="Téléphone" Binding="{Binding telephone}" Width="90"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding email}" Width="140"/>
                        <DataGridTextColumn Header="Ville" Binding="{Binding ville}" Width="70"/>
                        <DataGridTextColumn Header="Quartier" Binding="{Binding quartier}" Width="100"/>
                        <DataGridTemplateColumn Header="Fidélité" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E2E8F0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding fidelite}" Value="Fidèle">
                                                        <Setter Property="Background" Value="#EBF8FF"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding fidelite}" Value="VIP">
                                                        <Setter Property="Background" Value="#FEFCBF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <TextBlock Text="{Binding fidelite}" FontSize="12" FontWeight="Bold" Margin="8,4,8,4">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#4A5568"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding fidelite}" Value="Fidèle">
                                                            <Setter Property="Foreground" Value="#2B6CB0"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding fidelite}" Value="VIP">
                                                            <Setter Property="Foreground" Value="#B7791F"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="*" Header="Action">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="🗑️" Background="Transparent" BorderThickness="0" 
                                            Foreground="Red" FontSize="14" Cursor="Hand" HorizontalAlignment="Center"
                                            Click="BtnSupprimerClient_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>
