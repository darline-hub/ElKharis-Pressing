<Window x:Class="ElKharis.Views.SigninWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="El-Kharis - Inscription" Height="520" Width="750" 
        WindowStartupLocation="CenterScreen" 
        WindowStyle="None" 
        ResizeMode="NoResize"
        Background="#F4F6FA">
    <Border CornerRadius="15" Background="White">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="15,0,0,15">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A365D" Offset="0"/>
                        <GradientStop Color="#2B6CB0" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <Image Source="/Resources/logo.jpeg" Height="100" Width="200" HorizontalAlignment="Center" Margin="0,0,0,5" Stretch="Uniform"/>
                        <TextBlock Text="EL-KHARIS" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,0"/>
                        <TextBlock Text="L'excellence au service de votre éclat" Foreground="#CBD5E0" FontSize="10" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,0,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                        <Border Width="50" Height="3" Background="#4FD1C5" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="40,30,40,30">
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Foreground="#A0AEC0" FontWeight="Bold" FontSize="16" Cursor="Hand" Click="BtnAnnuler_Click"/>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Inscription" FontSize="26" FontWeight="Bold" Foreground="#2D3748" Margin="0,0,0,5"/>
                    <TextBlock Text="Renseignez les informations du nouvel employé" FontSize="12" Foreground="#718096" Margin="0,0,0,20"/>

                    <TextBlock Text="Nom d'utilisateur" FontSize="12" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,5"/>
                    <Border BorderThickness="1" BorderBrush="#CBD5E0" CornerRadius="6" Background="#F7FAFC" Padding="5" Margin="0,0,0,12">
                        <TextBox x:Name="TxtUsername" x:FieldModifier="public" BorderThickness="0" Background="Transparent" FontSize="14" Foreground="#2D3748" VerticalContentAlignment="Center" Height="25"/>
                    </Border>

                    <TextBlock Text="Adresse Email" FontSize="12" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,5"/>
                    <Border BorderThickness="1" BorderBrush="#CBD5E0" CornerRadius="6" Background="#F7FAFC" Padding="5" Margin="0,0,0,12">
                        <TextBox x:Name="TxtEmail" BorderThickness="0" Background="Transparent" FontSize="14" Foreground="#2D3748" VerticalContentAlignment="Center" Height="25"/>
                    </Border>

                    <TextBlock Text="Rôle de l'utilisateur" FontSize="12" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,5"/>
                    <Border BorderThickness="1" BorderBrush="#CBD5E0" CornerRadius="6" Background="#F7FAFC" Padding="5" Margin="0,0,0,12">
                        <ComboBox x:Name="CboRole" BorderThickness="0" Background="Transparent" FontSize="14" Foreground="#2D3748" VerticalContentAlignment="Center" Height="25" SelectedIndex="1">
                            <ComboBoxItem Content="Administrateur"/>
                            <ComboBoxItem Content="Réceptionniste"/>
                        </ComboBox>
                    </Border>

                    <TextBlock Text="Mot de passe" FontSize="12" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,5"/>
                    <Border BorderThickness="1" BorderBrush="#CBD5E0" CornerRadius="6" Background="#F7FAFC" Padding="5" Margin="0,0,0,20">
                        <PasswordBox x:Name="TxtPassword" BorderThickness="0" Background="Transparent" FontSize="14" Foreground="#2D3748" VerticalContentAlignment="Center" Height="25"/>
                    </Border>

                    <Button Content="S'inscrire" Background="#2B6CB0" Foreground="White" FontSize="14" FontWeight="Bold" Height="40" Cursor="Hand" BorderThickness="0" Click="BtnSignin_Click"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Déjà un compte ?" Foreground="#718096" FontSize="13"/>
                        <Button Content="Se connecter" Background="Transparent" Foreground="#2B6CB0" BorderThickness="0" FontSize="13" FontWeight="SemiBold" Margin="5,0,0,0" Cursor="Hand" Click="BtnAnnuler_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>