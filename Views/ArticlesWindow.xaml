<Window x:Class="ElKharis.Views.ArticlesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestion des articles"
        Height="620"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#173A63">
            <StackPanel Margin="20">
                <Image Source="/Resources/logo.jpeg"
                       Width="130"
                       Height="80"
                       Margin="0,20,0,10"/>

                <TextBlock Text="EL-KHARIS"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <Button Content="Tableau de bord"
                        Height="45"
                        Margin="0,0,0,10"
                        Click="BtnDashboard_Click"/>

                <Button Content="Commandes"
                        Height="45"
                        Margin="0,0,0,10"
                        Click="BtnCommandes_Click"/>

                <Button Content="Clients"
                        Height="45"
                        Margin="0,0,0,10"
                        Click="BtnClients_Click"/>

                <Button Content="Factures &amp; Reçus"
                        Height="45"
                        Margin="0,0,0,10"
                        Click="BtnFactures_Click"/>

                <Button Content="Articles"
                        Height="45"
                        Margin="0,0,0,10"
                        Background="#2F73B8"
                        Foreground="White"
                        Click="BtnArticles_Click"/>

                <Button Content="Services"
                        Height="45"
                        Margin="0,0,0,10"
                        Click="BtnServices_Click"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="35">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <TextBlock Text="Gestion des articles"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#173A63"/>

                <TextBlock Text="Ajouter, modifier et supprimer les articles du pressing"
                           FontSize="14"
                           Foreground="#8A9AB0"
                           Margin="0,5,0,0"/>
            </StackPanel>

            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="10"
                    Padding="20"
                    Margin="0,0,0,25">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="Nom de l'article"
                                   Foreground="#173A63"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,5"/>

                        <TextBox x:Name="TxtNomArticle"
                                 Height="38"
                                 VerticalContentAlignment="Center"
                                 Padding="10,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,15,0">
                        <TextBlock Text="Montant"
                                   Foreground="#173A63"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,5"/>

                        <TextBox x:Name="TxtMontant"
                                 Height="38"
                                 VerticalContentAlignment="Center"
                                 Padding="10,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,15,0">
                        <TextBlock Text="Description"
                                   Foreground="#173A63"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,5"/>

                        <TextBox x:Name="TxtDescription"
                                 Height="38"
                                 VerticalContentAlignment="Center"
                                 Padding="10,0"/>
                    </StackPanel>

                    <Button Grid.Column="3"
                            Content="Ajouter"
                            Width="95"
                            Height="38"
                            Margin="0,22,10,0"
                            Background="#2F73B8"
                            Foreground="White"
                            Click="BtnAjouter_Click"/>

                    <Button Grid.Column="4"
                            Content="Modifier"
                            Width="95"
                            Height="38"
                            Margin="0,22,10,0"
                            Background="#F59E0B"
                            Foreground="White"
                            Click="BtnModifier_Click"/>

                    <Button Grid.Column="5"
                            Content="Supprimer"
                            Width="95"
                            Height="38"
                            Margin="0,22,0,0"
                            Background="#DC2626"
                            Foreground="White"
                            Click="BtnSupprimer_Click"/>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Background="White"
                    CornerRadius="10"
                    Padding="15">

                <DataGrid x:Name="DgArticles"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          SelectionChanged="DgArticles_SelectionChanged">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding IdArticle}"
                                            Width="80"/>

                        <DataGridTextColumn Header="Nom de l'article"
                                            Binding="{Binding NomArticle}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Montant"
                                            Binding="{Binding Montant}"
                                            Width="150"/>

                        <DataGridTextColumn Header="Description"
                                            Binding="{Binding Description}"
                                            Width="250"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>