<Window x:Class="ElKharis.Views.FormUtilisateurWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ElKharis.Views"
        mc:Ignorable="d"
        Title="El-Kharis - Fiche Utilisateur" Height="400" Width="400"
        WindowStartupLocation="CenterOwner" 
        WindowStyle="None" 
        ResizeMode="NoResize"
        Background="#F4F6FA">   
    <Grid>
        <Grid Margin="20,30,20,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock x:Name="TxtTitreFormulaire" Text="Fiche Utilisateur" FontSize="22" FontWeight="Bold" Foreground="#1A365D"/>
                    <TextBlock Text="Saisissez les informations de l'utilisateur pour continuer" FontSize="12" Foreground="#718096" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Foreground="#A0AEC0" FontWeight="Bold" FontSize="16" Cursor="Hand" Click="BtnFermer_Click"/>
            </Grid>



            
            <StackPanel Grid.Row="1" VerticalAlignment="Top">

               
                <StackPanel x:Name="PanelId" Visibility="Collapsed" Margin="0,0,0,15">
                    <TextBlock Text="Identifiant (ID)" Foreground="#4A5568" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtId" Background="#E2E8F0" BorderBrush="#CBD5E0" BorderThickness="1" Padding="8,5" FontSize="14" IsReadOnly="True"/>
                </StackPanel>

               
                <TextBlock Text="Nom d'utilisateur" Foreground="#4A5568" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtNomUtilisateur" BorderBrush="#CBD5E0" BorderThickness="1.5" Padding="8,5" FontSize="14" Margin="0,0,0,15">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                
                <TextBlock Text="Adresse Email" Foreground="#4A5568" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtEmail" BorderBrush="#CBD5E0" BorderThickness="1.5" Padding="8,5" FontSize="14" Margin="0,0,0,15">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                
                <TextBlock Text="Rôle dans l'application" Foreground="#4A5568" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="CboRole" Height="35" BorderBrush="#CBD5E0" BorderThickness="1.5" FontSize="14" VerticalContentAlignment="Center" Margin="0,0,0,15">
                    <ComboBoxItem Content="Réceptionniste"/>
                    <ComboBoxItem Content="Administrateur"/>
                </ComboBox>
            </StackPanel>

            
            <UniformGrid Grid.Row="2" Columns="2" Rows="1" Height="40" Margin="0,10,0,0">
                <Button Content="Annuler" Background="#E2E8F0" Foreground="#4A5568" FontWeight="Bold" Margin="0,0,10,0" BorderThickness="0" Cursor="Hand" Click="BtnAnnuler_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Enregistrer" Background="#00A8CC" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnEnregistrer_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </UniformGrid>
        </Grid>

    </Grid>
</Window>
