<Window x:Class="ElKharis.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="El-Kharis - Connexion" Height="450" Width="750" 
        WindowStartupLocation="CenterScreen" 
        WindowStyle="None" 
        ResizeMode="NoResize"
        Background="#F4F6FA">
    <Border CornerRadius="15" Background="White">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="15,0,0,15">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A365D" Offset="0"/>
                        <GradientStop Color="#2B6CB0" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="✨" FontSize="48" HorizontalAlignment="Center"/>
                        <TextBlock Text="EL-KHARIS" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,5"/>
                        <TextBlock Text="Gestion de Pressing" FontSize="14" Foreground="#E2E8F0" HorizontalAlignment="Center"/>
                        <Border Width="50" Height="3" Background="#4FD1C5" Margin="0,20,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="40,30,40,30">
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Foreground="#A0AEC0" FontWeight="Bold" FontSize="16" Cursor="Hand" Click="BtnFermer_Click"/>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Connexion" FontSize="26" FontWeight="Bold" Foreground="#2D3748" Margin="0,0,0,5"/>
                    <TextBlock Text="Veuillez renseigner vos identifiants pour continuer" FontSize="12" Foreground="#718096" Margin="0,0,0,30"/>

                    <TextBlock Text="Nom d'utilisateur" FontSize="12" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,5"/>
                    <Border BorderThickness="1" BorderBrush="#CBD5E0" CornerRadius="6" Background="#F7FAFC" Padding="5" Margin="0,0,0,15">
                        <TextBox x:Name="TxtUsername" BorderThickness="0" Background="Transparent" FontSize="14" Foreground="#2D3748" VerticalContentAlignment="Center" Height="25"/>
                    </Border>

                    <TextBlock Text="Mot de passe" FontSize="12" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,5"/>
                    <Border BorderThickness="1" BorderBrush="#CBD5E0" CornerRadius="6" Background="#F7FAFC" Padding="5" Margin="0,0,0,25">
                        <PasswordBox x:Name="TxtPassword" BorderThickness="0" Background="Transparent" FontSize="14" Foreground="#2D3748" VerticalContentAlignment="Center" Height="25"/>
                    </Border>

                    <Button Content="Se connecter" Background="#2B6CB0" Foreground="White" FontSize="14" FontWeight="Bold" Height="40" Cursor="Hand" BorderThickness="0" Click="BtnLogin_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>