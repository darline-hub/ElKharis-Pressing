<Window x:Class="ElKharis.Views.NouvelleCommandeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enregistrer un dépôt - El Kharis" Height="550" Width="800"
        WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" 
        Background="Transparent">

    <Border Background="White" CornerRadius="15" BorderThickness="1" BorderBrush="#E2E8F0">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Nouveau Dépôt" FontSize="22" FontWeight="Bold" Foreground="#1A365D"/>
                    <TextBlock Text="Saisissez les détails du linge et sélectionnez le service" FontSize="12" Foreground="#718096"/>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Foreground="#A0AEC0" FontSize="18" Cursor="Hand" Click="BtnFermer_Click"/>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                    <TextBlock Text="Client" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#4A5568"/>
                    <ComboBox x:Name="CbClients" Height="40" Margin="0,0,0,15" VerticalContentAlignment="Center" 
                              DisplayMemberPath="nom_client" SelectedValuePath="id_client"/>

                    <TextBlock Text="Numéro de Commande" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#4A5568"/>
                    <TextBox x:Name="TxtNumero" Height="40" Margin="0,0,0,15" VerticalContentAlignment="Center" 
                             IsReadOnly="True" Background="#F7FAFC" Padding="10,0,0,0" Foreground="#718096"/>

                    <TextBlock Text="Description des vêtements (ex: 2 Vestes bleues, 1 Robe coton)" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#4A5568"/>
                    <TextBox x:Name="TxtArticles" Height="100" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,15" Padding="10"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="15,0,0,0">
                    <TextBlock Text="Service demandé" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#4A5568"/>
                    <ComboBox x:Name="CbServices" Height="40" Margin="0,0,0,15" VerticalContentAlignment="Center" 
                              DisplayMemberPath="nom_service" SelectedValuePath="id_service"/>

                    <TextBlock Text="Date de livraison prévue" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#4A5568"/>
                    <DatePicker x:Name="DpLivraison" Height="40" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

                    <Border Background="#F7FAFC" Padding="15" CornerRadius="10" BorderThickness="1" BorderBrush="#E2E8F0">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Montant Total (FCFA)" VerticalAlignment="Center" FontWeight="Medium" Foreground="#4A5568"/>
                                <TextBox x:Name="TxtTotal" HorizontalAlignment="Right" Width="140" Height="30" Text="0" 
                                         TextAlignment="Right" VerticalContentAlignment="Center" TextChanged="CalculerReste"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Réduction (FCFA)" VerticalAlignment="Center" FontWeight="Medium" Foreground="#4A5568"/>
                                <TextBox x:Name="TxtReduction" HorizontalAlignment="Right" Width="140" Height="30" Text="0" 
                                         TextAlignment="Right" VerticalContentAlignment="Center" TextChanged="CalculerReste"/>
                            </Grid>

                            <Separator Background="#E2E8F0" Margin="0,5,0,10"/>

                            <Grid>
                                <TextBlock Text="Reste à payer" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Foreground="#1A365D"/>
                                <TextBlock x:Name="TxtReste" Text="0 FCFA" HorizontalAlignment="Right" FontWeight="Bold" 
                                           FontSize="18" Foreground="#E53E3E" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Annuler" Width="110" Height="40" Background="Transparent" Foreground="#718096" 
                        BorderThickness="1" BorderBrush="#E2E8F0" Margin="0,0,12,0" Cursor="Hand" Click="BtnFermer_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Enregistrer le dépôt" Width="220" Height="40" Background="#00A3C4" Foreground="White" 
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnEnregistrer_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>