<Window x:Class="ElKharis.Views.NouvelleCommandeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enregistrer un dépôt - El Kharis" Height="580" Width="850"
        WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" 
        Background="Transparent">

    <Border Background="White" CornerRadius="15" BorderThickness="1" BorderBrush="#E2E8F0">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Nouveau Dépôt &amp; Facturation" FontSize="22" FontWeight="Bold" Foreground="#1A365D"/>
                    <TextBlock Text="Ajoutez les articles au panier pour générer le reçu de dépôt automatique" FontSize="12" Foreground="#718096"/>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Foreground="#A0AEC0" FontSize="18" Cursor="Hand" Click="BtnFermer_Click"/>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="430"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,15,0">

                    <TextBlock Text="Client" FontWeight="SemiBold" Margin="0,0,0,3" Foreground="#4A5568"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="CbClients" Grid.Column="0" Height="35" VerticalContentAlignment="Center" 
                                  DisplayMemberPath="nom_client" SelectedValuePath="id_client"/>
                        <Button x:Name="BtnAjouterClientRapide" Grid.Column="1" Content="➕ Nouveau" Width="95" Height="35" Margin="5,0,0,0"
                                Background="#28A745" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Click="BtnAjouterClientRapide_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>

                    <Border BorderThickness="1" BorderBrush="#CBD5E0" CornerRadius="8" Padding="10" Background="#F7FAFC" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="SÉLECTION DE L'ARTICLE" FontSize="11" FontWeight="Bold" Foreground="#2B6CB0" Margin="0,0,0,8"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Type de vêtement" FontSize="11" Margin="0,0,0,3" Foreground="#4A5568"/>
                                    <ComboBox x:Name="CbArticles" Height="32" VerticalContentAlignment="Center"
                                              DisplayMemberPath="nom_article" SelectedValuePath="id_article"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                    <TextBlock Text="Service" FontSize="11" Margin="0,0,0,3" Foreground="#4A5568"/>
                                    <ComboBox x:Name="CbServices" Height="32" VerticalContentAlignment="Center"
                                              DisplayMemberPath="nom_service" SelectedValuePath="id_service"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Qté" FontSize="11" Margin="0,0,0,3" Foreground="#4A5568"/>
                                    <TextBox x:Name="TxtQuantite" Height="32" Text="1" TextAlignment="Center" VerticalContentAlignment="Center" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>

                            <Button Content="➕ Ajouter cet article au dépôt" Height="32" Margin="0,12,0,0" Background="#2B6CB0" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Click="BtnAjouterAuPanier_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Articles inclus dans ce dépôt" FontWeight="SemiBold" Margin="0,3,0,3" Foreground="#4A5568"/>
                    <DataGrid x:Name="DgPanier" Height="165" AutoGenerateColumns="False" IsReadOnly="True" Background="White" BorderBrush="#CBD5E0" GridLinesVisibility="Horizontal" RowHeight="35" FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Désignation" Binding="{Binding Designation}" Width="*"/>
                            <DataGridTextColumn Header="Service" Binding="{Binding Service}" Width="90"/>
                            <DataGridTextColumn Header="P.U" Binding="{Binding PrixUnitaire, StringFormat=\{0:N0\}}" Width="65"/>
                            <DataGridTextColumn Header="Qté" Binding="{Binding Quantite}" Width="45"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding TotalLigne, StringFormat=\{0:N0\}}" Width="75" FontWeight="SemiBold"/>
                            <DataGridTemplateColumn Width="35">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="❌" ToolTip="Retirer cet article" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnSupprimerLignePanier_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="15,0,0,0">

                    <TextBlock Text="Numéro de Commande" FontWeight="SemiBold" Margin="0,0,0,3" Foreground="#4A5568"/>
                    <TextBox x:Name="TxtNumero" Height="35" Margin="0,0,0,10" VerticalContentAlignment="Center" 
                             IsReadOnly="True" Background="#F7FAFC" Padding="10,0,0,0" Foreground="#1A365D" FontWeight="Bold"/>

                    <TextBlock Text="Date de dépôt" FontWeight="SemiBold" Margin="0,0,0,3" Foreground="#4A5568"/>
                    <DatePicker x:Name="DpDepot" Height="35" Margin="0,0,0,12" VerticalContentAlignment="Center"/>

                    <TextBlock Text="Date de livraison prévue" FontWeight="SemiBold" Margin="0,0,0,3" Foreground="#4A5568"/>
                    <DatePicker x:Name="DpLivraison" Height="35" Margin="0,0,0,12" VerticalContentAlignment="Center"/>

                    <TextBlock Text="Mode de règlement" FontWeight="SemiBold" Margin="0,0,0,3" Foreground="#4A5568"/>
                    <ComboBox x:Name="CbModePaiement" SelectedIndex="0" Height="30" Margin="0,0,0,10">
                        <ComboBoxItem Content="Espèces"/>
                        <ComboBoxItem Content="Mobile Money"/>
                    </ComboBox>

                    <Border Background="#F7FAFC" Padding="12" CornerRadius="10" BorderThickness="1" BorderBrush="#E2E8F0">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Montant Total (FCFA)" VerticalAlignment="Center" FontWeight="Medium" Foreground="#4A5568"/>
                                <TextBox x:Name="TxtTotal" HorizontalAlignment="Right" Width="130" Height="28" Text="0" IsReadOnly="True" Background="#EDF2F7"
                                         TextAlignment="Right" VerticalContentAlignment="Center" FontWeight="Bold" TextChanged="CalculerReste"/>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Réduction (FCFA)" VerticalAlignment="Center" FontWeight="Medium" Foreground="#4A5568"/>
                                <TextBox x:Name="TxtReduction" HorizontalAlignment="Right" Width="130" Height="28" Text="0" 
                                         TextAlignment="Right" VerticalContentAlignment="Center" TextChanged="CalculerReste"/>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Avance versée (FCFA)" VerticalAlignment="Center" FontWeight="Medium" Foreground="#4A5568"/>
                                <TextBox x:Name="TxtAvance" HorizontalAlignment="Right" Width="130" Height="28" Text="0" 
                                         TextAlignment="Right" VerticalContentAlignment="Center" TextChanged="CalculerReste"/>
                            </Grid>

                            <Separator Background="#E2E8F0" Margin="0,3,0,8"/>

                            <Grid>
                                <TextBlock Text="Reste à payer" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" Foreground="#1A365D"/>
                                <TextBlock x:Name="TxtReste" Text="0 FCFA" HorizontalAlignment="Right" FontWeight="Bold" 
                                           FontSize="16" Foreground="#E53E3E" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Annuler" Width="110" Height="38" Background="Transparent" Foreground="#718096" 
                        BorderThickness="1" BorderBrush="#E2E8F0" Margin="0,0,12,0" Cursor="Hand" Click="BtnFermer_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="💾 Enregistrer" Width="250" Height="38" Background="#00A3C4" Foreground="White" 
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnEnregistrer_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>