<Window x:Class="ElKharis.Views.CommandesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ElKharis.Views"
        mc:Ignorable="d"
        Title="Commandes-ElKharis" Height="700" Width="1100">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>

        <Border Grid.Column="0" Background="#1A365D" BorderThickness="0,0,1,0" BorderBrush="#E2E8F0">
            <Grid Margin="10,20,10,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="1" Margin="0,0,10,0">
                    <Image Source="/Resources/logo.jpeg" Height="80" Width="130" HorizontalAlignment="Center" Margin="0,0,0,-5" Stretch="Uniform"/>
                    <TextBlock Text="EL-KHARIS" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,0"/>
                    <TextBlock Text="L'excellence au service de votre éclat" Foreground="#CBD5E0" FontSize="10" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,0,0,0" TextWrapping="Wrap" TextAlignment="Center"/>

                    <Border Background="#2B6CB0" CornerRadius="8" Padding="1" Margin="0,5,0,10">
                        <StackPanel HorizontalAlignment="Center" Margin="0,5,0,10">
                            <TextBlock x:Name="TxtUserNom" Text="Nom de l'utilisateur" Foreground="White" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                            <TextBlock x:Name="TxtUserRole" Text="Rôle" Foreground="#CBD5E0" FontSize="10" FontWeight="Medium" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Button Content="📊  Tableau de bord" Background="Transparent" Foreground="#E2E8F0" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Cursor="Hand" Click="BtnRetourDashboard_Click"/>
                    <Border Background="#2B6CB0" CornerRadius="8" Margin="0,5,0,0">
                        <Button Content="🧺  Commandes" Background="Transparent" Foreground="White" FontWeight="Bold" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0"/>
                    </Border>
                    <Button Content="👥 Clients" Background="Transparent" Foreground="#E2E8F0" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Cursor="Hand" Margin="0,5,0,0" Click="BtnClients_Click"/>
                    <Button  Content="💳 Factures &amp; Reçus" Background="Transparent" Foreground="White" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Click="BtnFactures_Click"/>
                    <Button x:Name="BtnArticles" Content="👕 Articles" Background="Transparent" Foreground="#E2E8F0" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Cursor="Hand" Margin="0,5,0,0" Click="BtnArticles_Click"/>
                    <Button x:Name="BtnServices" Content="🕒 Services" Background="Transparent" Foreground="#E2E8F0" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Cursor="Hand" Margin="0,5,0,0" Click="BtnServices_Click"/>
                    <Button x:Name="BtnUtilisateurs" Content="👥 Utilisateurs" Background="Transparent" Foreground="#E2E8F0" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Cursor="Hand" Margin="0,5,0,0" Click="BtnUtilisateurs_Click"/>
                </StackPanel>

                <Button Grid.Row="2" Content="Déconnexion" Background="#E53E3E" Foreground="White" FontWeight="Bold" FontSize="14" Height="40" Margin="15,0,15,0" Cursor="Hand" BorderThickness="0" Click="BtnLogout_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="30,25,30,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Commandes" FontSize="26" FontWeight="Bold" Foreground="#1A202C"/>
                    <TextBlock Text="Suivi en temps réel et gestion de l'état des vêtements reçus" FontSize="14" Foreground="#4A5568" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="+ Nouvelle commande" Width="160" Height="35" Background="#00A8CC" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="BtnNouvelleCommande_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="✕" Background="Transparent" BorderThickness="0" Foreground="#A0AEC0" FontWeight="Bold" FontSize="20" Cursor="Hand" Click="BtnQuitter_Click" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,25">
                <Button Content="🔍" FontSize="14" Background="#2B6CB0" Foreground="White" Width="36" Height="36" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Border BorderThickness="1.5" BorderBrush="#CBD5E0" CornerRadius="8" Background="White" Padding="12,5" Width="450" Height="36">
                    <Grid>
                        <TextBox x:Name="TxtRecherche" BorderThickness="0" Background="Transparent" FontSize="14" Foreground="#2D3748" VerticalContentAlignment="Center" TextChanged="TxtRecherche_TextChanged"/>
                        <TextBlock Text="Rechercher par numéro de commande, nom de client..." Foreground="#A0AEC0" IsHitTestVisible="False" VerticalAlignment="Center" Margin="5,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=TxtRecherche}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>
            </StackPanel>

            <UniformGrid Grid.Row="2" Columns="4" Rows="1" Height="90" Margin="0,0,0,25">
                <Border Background="White" CornerRadius="12" Margin="0,0,15,0" BorderThickness="3,1,1,1"  Padding="15,10">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Total Commandes" FontSize="14" Foreground="#A0AEC0" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtStatTotal" Text="-" FontSize="20" FontWeight="Bold" Foreground="#2B6CB0" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Margin="0,0,15,0" BorderThickness="3,1,1,1"  Padding="15,10">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="En Attente" FontSize="14" Foreground="#A0AEC0" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtStatEnAttente" Text="-" FontSize="20" FontWeight="Bold" Foreground="#DD6B20" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Margin="0,0,15,0" BorderThickness="3,1,1,1" Padding="15,10">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="En Cours de Traitement" FontSize="14" Foreground="#A0AEC0" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtStatEnCours" Text="-" FontSize="20" FontWeight="Bold" Foreground="#319795" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Margin="0,0,0,0" BorderThickness="3,1,1,1"  Padding="15,10">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Prêtes pour Retrait" FontSize="14" Foreground="#A0AEC0" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtStatPretes" Text="-" FontSize="20" FontWeight="Bold" Foreground="#38A169" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="3" Background="White" CornerRadius="12" BorderThickness="1" BorderBrush="#E2E8F0" Padding="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.04"/>
                </Border.Effect>

                <Border.Resources>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="12,0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type DataGridCell}">
                                    <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E2E8F0"/>
                                <Setter Property="Foreground" Value="#1A202C"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Resources>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="DgCommandes" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True" 
                  Background="Transparent" BorderThickness="0" RowHeaderWidth="0" GridLinesVisibility="Horizontal" 
                  HorizontalGridLinesBrush="#EDF2F7" RowHeight="48" FontSize="13.5" Foreground="#2D3748"
                  AlternatingRowBackground="#F8FAFC" MouseDoubleClick="DgCommandes_MouseDoubleClick">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="N° Commande" Binding="{Binding numero_commande}" Width="170"/>
                            <DataGridTextColumn Header="Clients" Binding="{Binding nom_complet}" Width="*"/>
                            <DataGridTextColumn Header="Date de Dépôt" Binding="{Binding date_commande, StringFormat=\{0:dd/MM/yyyy\}}" Width="100"/>
                            <DataGridTextColumn Header="Total Facturé" Binding="{Binding montant_total, StringFormat=\{0:N0\} FCFA}" Width="120"/>

                            <DataGridTemplateColumn Header="Statut" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,5" CornerRadius="20" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#EDF2F7"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding statut_commande}" Value="Creer">
                                                            <Setter Property="Background" Value="#FEEBC8"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding statut_commande}" Value="En attente">
                                                            <Setter Property="Background" Value="#FEEBC8"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding statut_commande}" Value="En cours de traitement">
                                                            <Setter Property="Background" Value="#EBF8FF"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding statut_commande}" Value="En traitement">
                                                            <Setter Property="Background" Value="#EBF8FF"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding statut_commande}" Value="Prête">
                                                            <Setter Property="Background" Value="#C6F6D5"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <TextBlock Text="{Binding statut_commande}" FontSize="11.5" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#4A5568"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding statut_commande}" Value="Creer">
                                                                <Setter Property="Foreground" Value="#C05621"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding statut_commande}" Value="En attente">
                                                                <Setter Property="Foreground" Value="#C05621"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding statut_commande}" Value="En cours de traitement">
                                                                <Setter Property="Foreground" Value="#2B6CB0"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding statut_commande}" Value="En traitement">
                                                                <Setter Property="Foreground" Value="#2B6CB0"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding statut_commande}" Value="Prête">
                                                                <Setter Property="Foreground" Value="#22543D"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            
                            <DataGridTemplateColumn Header="Avancer Statut" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="⏭️" ToolTip="Suivant"  Foreground="#2B6CB0" Background="Transparent" BorderThickness="0" Cursor="Hand" FontSize="14" Margin="0,0,12,0" Click="BtnSuivantStatut_Click" Tag="{Binding id_commande}">
                                        <Button.Style>
                                                <Style TargetType="Button">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding statut_commande}" Value="Livrée">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Actions" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="⚠️" ToolTip="Signaler un incident général" Foreground="#E53E3E" Background="Transparent" BorderThickness="0" Cursor="Hand" FontSize="14" Margin="0,0,10,0" Click="BtnSignalerIncidentGlobal_Click" Tag="{Binding id_commande}"/>
                                            <Button Content="📝" ToolTip="Modifier"  Foreground="Orange" Background="Transparent" BorderThickness="0" Cursor="Hand" FontSize="14" Margin="0,0,12,0" Click="BtnModifierCommande_Click" Tag="{Binding id_commande}"/>
                                            <Button Content="🗑️" ToolTip="Supprimer"  Foreground="Red" Background="Transparent" BorderThickness="0" Cursor="Hand" FontSize="14" Click="BtnSupprimerCommande_Click" Tag="{Binding id_commande}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                   

                    <Grid Grid.Row="1" Margin="10,15,10,5">
                        <TextBlock x:Name="TxtPaginationInfo" Text="Chargement des commandes..." Foreground="#718096" VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="12.5"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="&lt;" Width="35" Height="28" Margin="0,0,8,0" Background="White" BorderBrush="#CBD5E0" FontWeight="Bold" Cursor="Hand"/>
                            <Button Content="&gt;" Width="35" Height="28" Background="White" BorderBrush="#CBD5E0" FontWeight="Bold" Cursor="Hand"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>