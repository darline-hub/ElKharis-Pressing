<Window x:Class="ElKharis.Views.CommandesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="El-Kharis - Commandes" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen" WindowStyle="None" ResizeMode="NoResize"
        Background="#F4F6FA">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Background="#1A365D">
            <StackPanel Margin="10,20,10,10">
               
            </StackPanel>

            <Button Content="Déconnexion" VerticalAlignment="Bottom" Margin="10,0,10,20" Background="Transparent" Foreground="#E53E3E" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Cursor="Hand"/>
        </Grid>

        <Border Grid.Column="0" Background="#1A365D" BorderThickness="0,0,1,0" BorderBrush="#E2E8F0">
            <Grid Margin="10,20,10,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="1" Margin="0,0,10,0">
                    <Image Source="/Resources/logo.png" Height="80" Width="80" HorizontalAlignment="Center" Margin="0,0,0,15" Stretch="Uniform"/>
                    <TextBlock Text="EL-KHARIS" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                    <Border Background="#2B6CB0" CornerRadius="8" Padding="10" Margin="0,5,0,25">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="TxtUserNom" Text="Nom de l'utilisateur" Foreground="White" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                            <TextBlock x:Name="TxtUserRole" Text="Rôle" Foreground="#CBD5E0" FontSize="10" FontWeight="Medium" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Button Content="📊  Tableau de bord" Background="Transparent" Foreground="#E2E8F0" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Cursor="Hand" Click="BtnRetourDashboard_Click"/>
                    <Border Background="#2B6CB0" CornerRadius="8" Margin="0,5,0,0">
                        <Button Content="🧺  Commandes" Background="Transparent" Foreground="White" FontWeight="Bold" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0"/>
                    </Border>
                    <Button Content="👥 Clients" Background="Transparent" Foreground="#E2E8F0" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Cursor="Hand" Margin="0,5,0,0"/>
                    <Button Content="👕 Articles" Background="Transparent" Foreground="#E2E8F0" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Cursor="Hand" Margin="0,5,0,0"/>
                    <Button Content="🕒 Services" Background="Transparent" Foreground="#E2E8F0" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Cursor="Hand" Margin="0,5,0,0"/>
                </StackPanel>

                <Button Grid.Row="2" Content="Déconnexion" Background="#E53E3E" Foreground="White" FontWeight="Bold" FontSize="14" Height="40" Margin="15,0,15,0" Cursor="Hand" BorderThickness="0" Click="BtnLogout_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="30,20,30,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Button Content="☰" FontSize="20" Background="#00A3C4" Foreground="White" Width="40" Height="40" BorderThickness="0" Cursor="Hand" Margin="0,0,15,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="20"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Border BorderThickness="1" BorderBrush="#CBD5E0" CornerRadius="8" Background="White" Padding="10,5,10,5" Width="320">
                        <Grid>
                            <TextBox x:Name="TxtRecherche" BorderThickness="0" Background="Transparent" FontSize="14" Foreground="#2D3748" VerticalContentAlignment="Center" TextChanged="TxtRecherche_TextChanged"/>
                            <TextBlock Text="Rechercher une commande, client..." Foreground="#A0AEC0" IsHitTestVisible="False" VerticalAlignment="Center" Margin="5,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=TxtRecherche}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Foreground="#A0AEC0" FontWeight="Bold" FontSize="18" Cursor="Hand" Click="BtnQuitter_Click"/>

                <Border HorizontalAlignment="Right" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="15,10,15,10" Width="240">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Ellipse Width="35" Height="35" Fill="#E2E8F0" HorizontalAlignment="Left"/>
                            <StackPanel Margin="45,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Guy Bertrand Tchoffo" FontSize="13" FontWeight="Bold" Foreground="#2D3748"/>
                                <TextBlock Text="Administrateur" FontSize="11" Foreground="#A0AEC0"/>
                            </StackPanel>
                        </Grid>
                        <Button Content="+ Nouvelle commande" Background="#00A3C4" Foreground="White" FontWeight="Bold" FontSize="13" Height="32" Cursor="Hand" BorderThickness="0" Click="BtnNouvelleCommande_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                <TextBlock Text="Commandes" FontSize="24" FontWeight="Bold" Foreground="#2D3748"/>
                <TextBlock Text="Gérer toutes les commandes de votre pressing" FontSize="12" Foreground="#718096"/>
            </StackPanel>

            <UniformGrid Grid.Row="2" Columns="4" Rows="1" Height="85" Margin="0,0,0,20">
                <Border Background="White" CornerRadius="10" Margin="0,0,15,0" BorderThickness="1" BorderBrush="#CBD5E0" Padding="10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Total commandes" FontSize="12" Foreground="#718096" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtStatTotal" Text="120" FontSize="22" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="10" Margin="0,0,15,0" BorderThickness="1" BorderBrush="#CBD5E0" Padding="10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="En attente" FontSize="12" Foreground="#718096" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtStatEnAttente" Text="17" FontSize="22" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="10" Margin="0,0,15,0" BorderThickness="1" BorderBrush="#CBD5E0" Padding="10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="En traitement" FontSize="12" Foreground="#718096" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtStatEnCours" Text="28" FontSize="22" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="10" Margin="0,0,0,0" BorderThickness="1" BorderBrush="#CBD5E0" Padding="10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Prête" FontSize="12" Foreground="#718096" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtStatPretes" Text="50" FontSize="22" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="5,0,0,10">
                <TextBlock Text="Toutes(120)" Foreground="#00A3C4" FontWeight="Bold" FontSize="13" Margin="0,0,20,0" Cursor="Hand"/>
                <TextBlock Text="En attente(17)" Foreground="#2D3748" FontWeight="SemiBold" FontSize="13" Margin="0,0,20,0" Cursor="Hand"/>
                <TextBlock Text="En traitement(28)" Foreground="#2D3748" FontWeight="SemiBold" FontSize="13" Margin="0,0,20,0" Cursor="Hand"/>
                <TextBlock Text="Prêtes(50)" Foreground="#2D3748" FontWeight="SemiBold" FontSize="13" Margin="0,0,20,0" Cursor="Hand"/>
            </StackPanel>

            <Border Grid.Row="4" Background="White" CornerRadius="4" BorderThickness="1" BorderBrush="#A0AEC0" Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="DgCommandes" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True" Background="Transparent" BorderThickness="0" RowHeaderWidth="0" GridLinesVisibility="None" RowHeight="50" FontSize="13">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Width="40"/>
                            <DataGridTextColumn Header="N° Commande" Binding="{Binding numero_commande}" Width="160" FontWeight="SemiBold"/>
                            <DataGridTextColumn Header="Clients" Binding="{Binding nom_client}" Width="160"/>
                            <DataGridTextColumn Header="Statut" Binding="{Binding statut_commande}" Width="130"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding date_commande, StringFormat=\{0:dd/MM/yyyy\}}" Width="110"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding montant_total, StringFormat=\{0:N0\} FCFA}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="1" Margin="10,10,10,5">
                        <TextBlock x:Name="TxtPaginationInfo" Text="Affichage de 1 à 4 sur 120 commandes" Foreground="#718096" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="&lt;" Width="30" Height="25" Margin="0,0,10,0" Background="White" BorderBrush="#CBD5E0"/>
                            <Button Content="&gt;" Width="30" Height="25" Background="White" BorderBrush="#CBD5E0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>