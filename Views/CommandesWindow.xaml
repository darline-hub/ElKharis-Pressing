<Window x:Class="ElKharis.Views.CommandesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="El-Kharis - Commandes" Height="720" Width="1250"
        WindowStartupLocation="CenterScreen" WindowStyle="None" ResizeMode="NoResize"
        Background="#F4F6FA">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1A365D" BorderThickness="0,0,1,0" BorderBrush="#E2E8F0">
            <Grid Margin="10,20,10,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="1" Margin="0,0,10,0">
                    <Image Source="/Resources/logo.png" Height="80" Width="80" HorizontalAlignment="Center" Margin="0,0,0,-5" Stretch="Uniform"/>
                    <TextBlock Text="EL-KHARIS" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>

                    <Border Background="#2B6CB0" CornerRadius="8" Padding="1" Margin="0,5,0,10">
                        <StackPanel HorizontalAlignment="Center" Margin="0,5,0,10">
                            <TextBlock x:Name="TxtUserNom" Text="Nom Utilisateur" Foreground="White" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                            <TextBlock x:Name="TxtUserRole" Text="Rôle" Foreground="#CBD5E0" FontSize="10" FontWeight="Medium" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Button Content="📊  Tableau de bord" Background="Transparent" Foreground="#E2E8F0" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Cursor="Hand" Click="BtnRetourDashboard_Click"/>
                    <Border Background="#2B6CB0" CornerRadius="8" Margin="0,5,0,0">
                        <Button Content="🧺  Commandes" Background="Transparent" Foreground="White" FontWeight="Bold" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0"/>
                    </Border>
                    <Button Content="👥 Clients" Background="Transparent" Foreground="#E2E8F0" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Cursor="Hand" Margin="0,5,0,0" Click="BtnClients_Click"/>
                    <Button Content="👕 Articles" Background="Transparent" Foreground="#E2E8F0" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Cursor="Hand" Margin="0,5,0,0"/>
                    <Button Content="🕒 Services" Background="Transparent" Foreground="#E2E8F0" Height="40" BorderThickness="0" HorizontalContentAlignment="Left" Padding="15,0,0,0" Cursor="Hand" Margin="0,5,0,0"/>
                </StackPanel>

                <Button Grid.Row="2" Content="Déconnexion" Background="#E53E3E" Foreground="White" FontWeight="Bold" FontSize="14" Height="40" Margin="15,0,15,0" Cursor="Hand" BorderThickness="0" Click="BtnLogout_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="30,20,30,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Button Content="🔍" FontSize="16" Background="#00A3C4" Foreground="White" Width="35" Height="35" BorderThickness="0" Cursor="Hand" Margin="0,0,15,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="17.5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Border BorderThickness="1" BorderBrush="#CBD5E0" CornerRadius="8" Background="White" Padding="10,5,10,5" Width="320" Height="35">
                        <Grid>
                            <TextBox x:Name="TxtRecherche" BorderThickness="0" Background="Transparent" FontSize="14" Foreground="#2D3748" VerticalContentAlignment="Center" TextChanged="TxtRecherche_TextChanged"/>
                            <TextBlock Text="Rechercher une commande, client..." Foreground="#A0AEC0" IsHitTestVisible="False" VerticalAlignment="Center" Margin="5,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=TxtRecherche}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="+ Nouvelle commande" Background="#00A3C4" Foreground="White" FontWeight="Bold" FontSize="13" Height="35" Cursor="Hand" BorderThickness="0" Padding="15,0" Click="BtnNouvelleCommande_Click" Margin="0,0,15,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="✕" Background="Transparent" BorderThickness="0" Foreground="#A0AEC0" FontWeight="Bold" FontSize="18" Cursor="Hand" Click="BtnQuitter_Click" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                <TextBlock Text="Commandes" FontSize="24" FontWeight="Bold" Foreground="#2D3748"/>
                <TextBlock Text="Gérer toutes les commandes de votre pressing" FontSize="12" Foreground="#718096"/>
            </StackPanel>

            <UniformGrid Grid.Row="2" Columns="4" Rows="1" Height="85" Margin="0,0,0,20">
                <Border Background="White" CornerRadius="10" Margin="0,0,15,0" BorderThickness="1" BorderBrush="#CBD5E0" Padding="10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Total commandes" FontSize="12" Foreground="#718096" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtStatTotal" Text="-" FontSize="22" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="10" Margin="0,0,15,0" BorderThickness="1" BorderBrush="#CBD5E0" Padding="10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="En attente" FontSize="12" Foreground="#718096" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtStatEnAttente" Text="-" FontSize="22" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="10" Margin="0,0,15,0" BorderThickness="1" BorderBrush="#CBD5E0" Padding="10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="En traitement" FontSize="12" Foreground="#718096" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtStatEnCours" Text="-" FontSize="22" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="10" Margin="0,0,0,0" BorderThickness="1" BorderBrush="#CBD5E0" Padding="10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Prête" FontSize="12" Foreground="#718096" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtStatPretes" Text="-" FontSize="22" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="4" Background="White" CornerRadius="4" BorderThickness="1" BorderBrush="#A0AEC0" Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="DgCommandes" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True" 
                              Background="Transparent" BorderThickness="0" RowHeaderWidth="0" GridLinesVisibility="None" 
                              RowHeight="50" FontSize="13" MouseDoubleClick="DgCommandes_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="N° Commande" Binding="{Binding numero_commande}" Width="150" FontWeight="SemiBold"/>
                            <DataGridTextColumn Header="Clients" Binding="{Binding nom_client}" Width="*"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding date_commande, StringFormat=\{0:dd/MM/yyyy\}}" Width="120"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding montant_total, StringFormat=\{0:N0\} FCFA}" Width="130"/>

                            <DataGridTemplateColumn Header="Statut" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,4,8,4" CornerRadius="4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#EDF2F7"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding statut_commande}" Value="En attente">
                                                            <Setter Property="Background" Value="#FEEBC8"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding statut_commande}" Value="En cours de traitement">
                                                            <Setter Property="Background" Value="#EBF8FF"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding statut_commande}" Value="En traitement">
                                                            <Setter Property="Background" Value="#EBF8FF"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding statut_commande}" Value="Prête">
                                                            <Setter Property="Background" Value="#C6F6D5"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <TextBlock Text="{Binding statut_commande}" FontSize="12" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#4A5568"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding statut_commande}" Value="En attente">
                                                                <Setter Property="Foreground" Value="#C05621"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding statut_commande}" Value="En cours de traitement">
                                                                <Setter Property="Foreground" Value="#2B6CB0"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding statut_commande}" Value="En traitement">
                                                                <Setter Property="Foreground" Value="#2B6CB0"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding statut_commande}" Value="Prête">
                                                                <Setter Property="Foreground" Value="#22543D"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Actions" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="📝" ToolTip="Modifier" Background="Transparent" BorderThickness="0" Cursor="Hand" FontSize="14" Margin="0,0,10,0" Click="BtnModifierCommande_Click" Tag="{Binding id_commande}"/>
                                            <Button Content="🗑️" ToolTip="Supprimer" Background="Transparent" BorderThickness="0" Cursor="Hand" FontSize="14" Click="BtnSupprimerCommande_Click" Tag="{Binding id_commande}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="1" Margin="10,10,10,5">
                        <TextBlock x:Name="TxtPaginationInfo" Text="Chargement des commandes..." Foreground="#718096" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="&lt;" Width="30" Height="25" Margin="0,0,10,0" Background="White" BorderBrush="#CBD5E0"/>
                            <Button Content="&gt;" Width="30" Height="25" Background="White" BorderBrush="#CBD5E0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>